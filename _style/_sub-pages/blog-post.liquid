@import url('../_components/global.css');
@import url('../_components/palette.css');

.title {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
}

.blog-post-title {
    font-size: var(--h2);
    font-weight: var(--dark);
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

/* Tags section */
.blog-post-tags {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
}

.tags {
    padding: 0.3rem 1rem;
    color: var(--text-primary);
}

{% comment %} Image captions {% endcomment %}
.content figure {
    margin: 1.5rem 0;
    text-align: center;
}

.content figure img {
    max-width: 100%;
    margin: 0;
}

.content figure figcaption {
    margin-top: 0.5rem;
    font-size: var(--regular);
    color: var(--text-secondary);
    font-style: italic;
}
