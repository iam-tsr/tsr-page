@import url('https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@100;200;300;400;500&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap');

body {
    margin: 0;
    line-height: 1.5rem;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    overflow-x: hidden;
    transition: background-color 0.5s ease, color 0.5s ease;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

/* Header & Navigation */
header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    z-index: 1000;
    padding: 0.7rem 0;
    transition: background-color 0.5s ease;
}

nav {
    max-width: {{ site.width }};
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* Client Name */
.logo {
    display: flex;
    align-items: center;
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--h4);
    transition: var(--transition);
    font-weight: 700;
}

.logo:hover {
    color: var(--accent-color);
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 1rem;
    justify-content: flex-end;
    flex-wrap: wrap;
    align-items: center;
}

.nav-link {
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--regular);
    transition: var(--transition);
    position: relative;
}

.nav-link:hover,
.nav-link.active {
    color: var(--accent-color);
}

.nav-link.active::after {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--accent-color);
}

.nav-links i {
    font-size: var(--regular);
}

/* Hamburger Menu */
.hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    justify-content: flex-start;
}

.hamburger .bar {
    width: 25px;
    height: 3px;
    background-color: var(--text-primary);
    transition: var(--transition);
    border-radius: 3px;
}

.hamburger:hover .bar {
    background-color: var(--accent-color);
}

.hamburger.active .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
}

.hamburger.active .bar:nth-child(2) {
    opacity: 0;
}

.hamburger.active .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
}

/* Main Content */
main {
    flex: 1;
    width: 90%;
    max-width: {{ site.width }};
    margin: 0 auto;
    padding: 6rem 1rem 4rem;
}

/* Footer */
.footer {
    background-color: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 1rem 0;
    text-align: center;
}

.footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
}

.footer-icons {
    display: flex;
    align-items: center;
}

.contact-link {
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--h1);
    transition: var(--transition);
}

.contact-link:hover {
    color: var(--accent-color);
}

.footer-content p {
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--very-small);
    margin: 0;
}

/* Hero Section */
.section-title {
    font-size: var(--h2);
    color: var(--text-primary);
    line-height: 1.2;
    font-weight: 200;
    margin-bottom: 0;
    margin-top: 0;
}

.caption {
    margin: 0;
    font-size: var(--regular);
    color: var(--text-primary);
    margin-bottom: 2rem;
    font-weight: 200;
}

.dot {
    color: var(--text-secondary)
}

.button {
    margin-bottom: 0.5rem;
    font-weight: 400;
    font-size: var(--very-small);
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    text-decoration: none;
    border-bottom: solid 2px var(--accent-color);
    padding: 0.3rem 0.7rem;
    margin-right: 0.5rem;
}

.button:hover {
    background-color: var(--accent-color);
    border-radius: 2px;
    border-color: var(--accent-color);
    color: inherit;
    transition-duration: 0.3s;
}

/* Additional Content Assets */

/* Theme Toggle Icon */
.theme-icon {
    color: var(--text-primary);
    font-size: var(--very-small-icon);
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
}

.theme-icon:hover {
    color: var(--accent-color);
}

/* Scroll to Top Button */
.scroll-to-top {
    position: fixed;
    bottom: 5rem;
    right: 2rem;
    width: 45px;
    height: 45px;
    background-color: var(--border-color);
    color: var(--text-secondary);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--very-small-icon);
    opacity: 0;
    visibility: hidden;
    transition: var(--transition);
    z-index: 998;
}

.scroll-to-top.visible {
    opacity: 1;
    visibility: visible;
}

.scroll-to-top:hover {
    transform: translateY(-3px);
}

/* Responsive Design */
@media (max-width: 768px) {

}

@media (max-width: 674px) {

    .contact-link {
        font-size: var(--small-icon);
    }

    /* Mobile Navigation */
    .hamburger {
        display: flex;
    }

    .nav-links {
        position: fixed;
        top: 0;
        right: 0;
        height: 100%;
        width: 30%;

        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-end;
        padding: 4rem 1.5rem 1rem 0;
        line-height: 1.5;

        background-color: var(--bg-tertiary);
        backdrop-filter: blur(6px);
        border-left: 1px solid var(--border-color);

        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 998;
    }

    .nav-links.active {
        transform: translateX(0);
    }
}
